# Copy to .env.local and fill in. When VITE_SUPABASE_URL is empty the
# dashboard falls back to the in-memory demo store.

# Supabase project URL (e.g. https://xyzcompany.supabase.co).
VITE_SUPABASE_URL=

# Supabase anon (public) key. The browser is NOT allowed the service role
# key — RLS is the security boundary.
VITE_SUPABASE_ANON_KEY=

# Which model_lines.slug the dashboard scopes its queries to.
VITE_MODEL_LINE_SLUG=seeds-poc

# Demo R2 quota in megabytes.
VITE_STORAGE_QUOTA_MB=32
