SUPABASE_ANON_KEY=<filled by `supabase start`>
SUPABASE_SERVICE_ROLE_KEY=<filled by `supabase start`>

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=advance-seeds-models
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_BASE=
