{
  "model_name": "yolo26n-seg",
  "model_version": "0.1.0",
  "task": "instance-segmentation",
  "input_size": 640,
  "source_weights": "yolo26n-seg.pt",
  "mobile_tflite_filename": "yolo11n-seeds.tflite",
  "class_names": [
    "apple",
    "banana",
    "broccoli",
    "carrot",
    "orange"
  ],
  "output_kind": "end2end_nms_free",
  "output_shape": [1, 300, 6],
  "score_threshold": 0.5,
  "iou_threshold": 0.75,
  "calibration": {
    "required": true,
    "supported_sources": ["aruco", "lidar", "manual"],
    "default_marker_mm": 50.0
  },
  "acceptance_targets": {
    "segmentation_map": 0.85,
    "mask_map": 0.8,
    "measurement_error_mm": 0.5
  }
}
